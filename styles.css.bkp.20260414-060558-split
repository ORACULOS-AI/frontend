:root {
    --black: #000;
    --white: #fff;
    --blue: #00D4FF;
    --gray: #888;
    --gray-dark: #333;
    --font-display: 'Bebas Neue', sans-serif;
    --font-body: 'Inter', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; font-size: 16px; }
html::-webkit-scrollbar { width: 4px; }
html::-webkit-scrollbar-track { background: var(--black); }
html::-webkit-scrollbar-thumb { background: var(--blue); }
body {
    font-family: var(--font-body);
    background: var(--black);
    color: var(--white);
    line-height: 1.6;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
}
a { color: inherit; text-decoration: none; }
img, video { max-width: 100%; display: block; }
button { font-family: inherit; cursor: pointer; border: none; background: none; color: inherit; }
ul, ol { list-style: none; }
.noise-overlay {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 9999;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px;
}

/* NAVBAR */
.navbar {
    position: fixed;
    top: 0; left: 0;
    width: 100%;
    z-index: 1000;
    padding: 20px 32px;
    transition: background 0.3s ease;
}
.navbar-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.navbar-logo {
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.12em;
}
.navbar-links {
    display: flex;
    gap: 28px;
}
.navbar-links a {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray);
    transition: color 0.2s ease;
}
.navbar-links a:hover { color: var(--white); }
.navbar-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
}
.navbar-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--white);
}
.mobile-menu {
    position: fixed;
    top: 0; right: -100%;
    width: 100%; height: 100vh;
    background: var(--black);
    z-index: 1001;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 24px;
    transition: right 0.35s ease;
}
.mobile-menu.active { right: 0; }
.mobile-menu-close {
    position: absolute;
    top: 20px; right: 32px;
    font-size: 2rem;
}
.mobile-menu a {
    font-family: var(--font-display);
    font-size: 2rem;
    letter-spacing: 0.05em;
    color: var(--gray);
    transition: color 0.2s ease;
}
.mobile-menu a:hover { color: var(--blue); }

/* HERO — video fullscreen background */
.hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}
.hero-video-bg {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: 0;
}
.hero-overlay {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.55);
    z-index: 1;
}
.hero-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    padding: 0 24px;
}
.hero-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 20px;
}
.hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 9vw, 7rem);
    line-height: 0.95;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-bottom: 20px;
}
.hero-title .outline {
    -webkit-text-stroke: 1.5px var(--white);
    color: transparent;
}
.hero-subtitle {
    font-size: 1rem;
    color: var(--gray);
    max-width: 500px;
    margin: 0 auto 36px;
    line-height: 1.7;
}
.hero-ctas {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 48px;
}
.btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--black);
    background: var(--white);
    border: 2px solid var(--white);
    transition: all 0.2s ease;
}
.btn-primary:hover {
    background: transparent;
    color: var(--white);
}
.btn-primary .arrow { transition: transform 0.2s ease; }
.btn-primary:hover .arrow { transform: translateX(4px); }
.btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--white);
    background: transparent;
    border: 2px solid var(--gray-dark);
    transition: all 0.2s ease;
}
.btn-secondary:hover {
    border-color: var(--blue);
    color: var(--blue);
}
.hero-scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: var(--gray);
}
.hero-scroll-hint span {
    font-size: 1.5rem;
    animation: scrollBounce 2s ease-in-out infinite;
}
.hero-scroll-hint small {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
}
@keyframes scrollBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
}

/* SECTION BASE */
.section {
    position: relative;
    padding: 120px 32px;
    z-index: 1;
}
.section-inner {
    max-width: 1100px;
    margin: 0 auto;
}
.section-dark { background: var(--black); }
.section-header { margin-bottom: 60px; }
.section-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--blue);
    margin-bottom: 16px;
}
.section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: 0.02em;
    text-transform: uppercase;
}
.section-subtitle {
    margin-top: 12px;
    font-size: 1rem;
    color: var(--gray);
    max-width: 550px;
}
.section-number {
    position: absolute;
    top: 24px; right: 32px;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--gray-dark);
    letter-spacing: 0.1em;
}
.glitch-divider {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gray-dark), transparent);
    margin: 0;
}

/* SPLIT LAYOUT (2 columns) */
.split-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
}
.split-text {
    display: flex;
    flex-direction: column;
    gap: 20px;
}
.split-visual {
    position: relative;
}
.visual-card {
    position: relative;
    padding: 32px;
    border: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.02);
}
.visual-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: linear-gradient(135deg, rgba(0, 212, 255, 0.03) 0%, transparent 50%);
    pointer-events: none;
}

/* TEAM GRID IN VISUAL COLUMN */
.team-grid-visual {
    padding: 24px;
    border: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.02);
    max-height: 600px;
    overflow-y: auto;
}
.team-grid-visual::-webkit-scrollbar {
    width: 3px;
}
.team-grid-visual::-webkit-scrollbar-track {
    background: transparent;
}
.team-grid-visual::-webkit-scrollbar-thumb {
    background: var(--blue);
}
.team-grid-visual .team-member {
    padding: 16px 8px 12px;
}
.team-grid-visual .team-member-avatar {
    width: 40px; height: 40px;
    font-size: 0.9rem;
    margin-bottom: 8px;
}
.team-grid-visual .team-member-name {
    font-size: 0.85rem;
}
.team-grid-visual .team-member-role {
    font-size: 0.5rem;
}
.team-grid-visual .team-member-overlay {
    padding: 4px;
}
.team-grid-visual .team-member-tag {
    font-size: 0.4rem;
    padding: 1px 4px;
}

/* MANIFESTO */
.manifesto-text {
    font-size: 1.05rem;
    color: var(--gray);
    line-height: 1.8;
    margin-bottom: 0;
    max-width: 100%;
}
.manifesto-text strong { color: var(--white); font-weight: 600; }
.manifesto-ufc {
    font-size: 0.85rem;
    color: var(--gray-dark);
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.06);
}
.manifesto-ufc a { color: var(--blue); text-decoration: underline; text-underline-offset: 3px; }
.manifesto-divider {
    width: 100%;
    max-width: 300px;
    margin: 0 0 24px 0;
}
.manifesto-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 0;
}
.stat-card {
    position: relative;
    padding: 20px;
    border: 1px solid rgba(255,255,255,0.06);
}
.stat-card::before {
    content: attr(data-index);
    position: absolute;
    top: 8px; right: 10px;
    font-family: var(--font-mono);
    font-size: 0.5rem;
    color: var(--blue);
    opacity: 0.4;
}
.stat-value {
    font-family: var(--font-display);
    font-size: 1.8rem;
    letter-spacing: 0.05em;
}
.stat-label {
    font-size: 0.7rem;
    color: var(--gray-dark);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 2px;
}

/* CAPABILITIES */
.capabilities-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2px;
    background: rgba(255,255,255,0.04);
}
.capability-card {
    position: relative;
    padding: 32px 24px;
    background: var(--black);
    transition: background 0.2s ease;
}
.capability-card:hover { background: var(--gray-dark); }
.capability-icon {
    width: 32px; height: 32px;
    margin-bottom: 16px;
    color: var(--blue);
}
.capability-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
}
.capability-desc {
    font-size: 0.85rem;
    color: var(--gray);
    line-height: 1.6;
}
.capability-metric {
    display: inline-block;
    margin-top: 12px;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--blue);
    padding: 3px 10px;
    border: 1px solid rgba(0, 212, 255, 0.3);
    opacity: 0.8;
}
.capability-card:hover .capability-icon {
    color: var(--white);
    animation: iconPulse 1s ease infinite;
}
.capability-card:hover .capability-metric {
    opacity: 1;
    background: rgba(0, 212, 255, 0.1);
}
@keyframes iconPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
}

/* CAPABILITIES LIST (left column) */
.capabilities-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
}
.capability-list-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.04);
    transition: all 0.3s ease;
}
.capability-list-item:hover {
    border-color: var(--blue);
    background: rgba(0, 212, 255, 0.03);
}
.capability-list-icon {
    flex-shrink: 0;
    width: 36px; height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--blue);
}
.capability-list-icon svg {
    width: 28px; height: 28px;
}
.capability-list-item strong {
    color: var(--white);
}
.capability-list-item div {
    flex: 1;
    font-size: 0.85rem;
    color: var(--gray);
}
.capability-list-metric {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

/* CAPABILITIES VISUAL (right column) */
.capabilities-visual {
    position: relative;
    padding: 24px;
    border: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.02);
}
.capabilities-grid-compact {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
}
.capabilities-grid-compact .capability-card {
    padding: 20px 16px;
    text-align: center;
}
.capabilities-grid-compact .capability-icon {
    margin: 0 auto 12px;
}
.capabilities-grid-compact .capability-title {
    font-size: 1rem;
}
.capabilities-grid-compact .capability-metric {
    margin-top: 8px;
}

/* MARQUEE */
.marquee-section {
    position: relative;
    padding: 20px 0;
    overflow: hidden;
    border-top: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    z-index: 1;
}
.marquee-track {
    display: flex;
    animation: marqueeScroll 25s linear infinite;
    width: max-content;
}
.marquee-track:hover { animation-play-state: paused; }
.marquee-item {
    flex-shrink: 0;
    padding: 0 32px;
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.5vw, 2rem);
    letter-spacing: 0.1em;
    color: var(--white);
    white-space: nowrap;
    opacity: 0.5;
    transition: opacity 0.2s ease;
}
.marquee-item:hover { opacity: 1; }
.marquee-separator {
    flex-shrink: 0;
    padding: 0 8px;
    color: var(--blue);
    font-size: 0.8rem;
    opacity: 0.3;
}
@keyframes marqueeScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}

/* OPEN SOURCE */
.opensource-card {
    max-width: 650px;
    padding: 40px;
    border: 1px solid rgba(255,255,255,0.06);
}
.opensource-header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
}
.opensource-title {
    font-family: var(--font-display);
    font-size: 1.6rem;
    letter-spacing: 0.05em;
}
.opensource-version {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--blue);
    margin-top: 4px;
}
.opensource-badges { display: flex; gap: 8px; flex-wrap: wrap; }
.badge {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 4px 12px;
    border: 1px solid;
}
.badge--blue { color: var(--blue); border-color: var(--blue); }
.badge-white { color: var(--black); background: var(--white); border-color: var(--white); }
.opensource-desc {
    font-size: 0.9rem;
    color: var(--gray);
    line-height: 1.6;
    margin-bottom: 24px;
}

/* GITHUB STATS */
.github-stats {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    padding: 20px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.06);
    margin-bottom: 24px;
}
.github-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
}
.github-stat-icon {
    color: var(--blue);
    font-size: 1rem;
    opacity: 0.8;
}
.github-stat-value {
    font-family: var(--font-display);
    font-size: 1.8rem;
    letter-spacing: 0.05em;
    color: var(--white);
}
.github-stat-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray-dark);
}

/* RECENT COMMITS */
.recent-commits {
    margin-bottom: 24px;
}
.recent-commits-title {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--blue);
    margin-bottom: 12px;
}
.commit-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.commit-item {
    display: flex;
    gap: 12px;
    padding: 8px 12px;
    background: rgba(255,255,255,0.02);
    border-left: 2px solid var(--blue);
    font-size: 0.75rem;
}
.commit-time {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--gray-dark);
    white-space: nowrap;
    min-width: 50px;
}
.commit-msg {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--gray);
}
.terminal {
    background: var(--gray-dark);
    border: 1px solid rgba(255,255,255,0.08);
    overflow: hidden;
}
.terminal-header {
    display: flex;
    gap: 6px;
    padding: 10px 14px;
    background: rgba(255,255,255,0.03);
    border-bottom: 1px solid rgba(255,255,255,0.06);
}
.terminal-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
}
.terminal-dot.red { background: #ff5f57; }
.terminal-dot.yellow { background: #febc2e; }
.terminal-dot.green { background: #28c840; }
.terminal-content {
    padding: 16px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--blue);
    line-height: 1.8;
    min-height: 100px;
}
.terminal-cursor {
    display: inline-block;
    width: 8px; height: 14px;
    background: var(--blue);
    animation: cursorBlink 1s step-end infinite;
}
@keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
}

/* TEAM */
.team-text {
    font-size: 0.95rem;
    color: var(--gray);
    line-height: 1.7;
    margin-bottom: 16px;
    max-width: 600px;
}
.team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 12px;
    margin-bottom: 24px;
}
.team-member {
    position: relative;
    padding: 24px 12px 16px;
    border: 1px solid rgba(255,255,255,0.05);
    text-align: center;
    transition: all 0.3s ease;
    overflow: hidden;
    cursor: default;
}
.team-member::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: linear-gradient(135deg, transparent 0%, rgba(0, 212, 255, 0.05) 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
}
.team-member:hover::before {
    opacity: 1;
}
.team-member:hover {
    border-color: var(--blue);
    transform: translateY(-4px);
}
.team-member-avatar {
    position: relative;
    width: 56px; height: 56px;
    margin: 0 auto 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--black);
    background: linear-gradient(135deg, var(--white), var(--blue));
    border-radius: 50%;
    border: 2px solid transparent;
    transition: all 0.3s ease;
}
.team-member:hover .team-member-avatar {
    border-color: var(--blue);
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.4);
}
.avatar-placeholder {
    position: relative;
    z-index: 1;
}
.team-member-info {
    position: relative;
    z-index: 1;
}
.team-member-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.05em;
}
.team-member-role {
    font-size: 0.6rem;
    color: var(--gray-dark);
    margin-top: 2px;
}
.team-member-overlay {
    position: absolute;
    bottom: 0; left: 0;
    width: 100%;
    padding: 8px;
    background: linear-gradient(transparent, rgba(0,0,0,0.9));
    transform: translateY(100%);
    transition: transform 0.3s ease;
}
.team-member:hover .team-member-overlay {
    transform: translateY(0);
}
.team-member-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--blue);
    padding: 2px 8px;
    border: 1px solid rgba(0,212,255,0.3);
}

/* AVATAR SCAN EFFECT */
.team-member-avatar::after {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 2px;
    background: var(--blue);
    opacity: 0;
    transition: opacity 0.3s ease;
}
.team-member:hover .team-member-avatar::after {
    opacity: 0.6;
    animation: avatarScan 1.5s ease-in-out infinite;
}
@keyframes avatarScan {
    0%, 100% { top: 0; }
    50% { top: calc(100% - 2px); }
}
.team-areas {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
}
.area-badge {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 4px 12px;
    border: 1px solid rgba(255,255,255,0.08);
    color: var(--gray-dark);
}

/* FOOTER */
.footer {
    position: relative;
    padding: 60px 32px 32px;
    border-top: 1px solid rgba(255,255,255,0.05);
    z-index: 1;
}
.footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 40px;
}
.footer-brand { max-width: 350px; }
.footer-logo {
    font-family: var(--font-display);
    font-size: 1.4rem;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
}
.footer-tagline {
    font-size: 0.8rem;
    color: var(--gray-dark);
    line-height: 1.6;
}
.footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 48px;
}
.footer-col-title {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--blue);
    margin-bottom: 12px;
}
.footer-col a {
    display: block;
    font-size: 0.8rem;
    color: var(--gray);
    padding: 3px 0;
    transition: color 0.2s ease;
}
.footer-col a:hover { color: var(--white); }
.footer-bottom {
    max-width: 1100px;
    margin: 32px auto 0;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.04);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
}
.footer-copy {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--gray-dark);
}
.footer-socials { display: flex; gap: 20px; }
.footer-socials a {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray-dark);
    transition: color 0.2s ease;
}
.footer-socials a:hover { color: var(--blue); }

/* REVEAL ANIMATIONS */
.reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
}
.reveal.revealed {
    opacity: 1;
    transform: translateY(0);
}
.reveal-delay-1 { transition-delay: 0.1s; }
.reveal-delay-2 { transition-delay: 0.2s; }
.reveal-delay-3 { transition-delay: 0.3s; }
.reveal-delay-4 { transition-delay: 0.4s; }
.reveal-delay-5 { transition-delay: 0.5s; }
.reveal-delay-6 { transition-delay: 0.6s; }

/* GLITCH EFFECT */
@keyframes glitch1 {
    0%, 100% { clip-path: inset(0 0 100% 0); transform: translate(0); }
    20% { clip-path: inset(20% 0 60% 0); transform: translate(-2px, 2px); }
    40% { clip-path: inset(60% 0 10% 0); transform: translate(2px, -2px); }
    60% { clip-path: inset(40% 0 30% 0); transform: translate(-1px, 1px); }
    80% { clip-path: inset(10% 0 80% 0); transform: translate(1px, -1px); }
}
@keyframes glitch2 {
    0%, 100% { clip-path: inset(100% 0 0 0); transform: translate(0); }
    20% { clip-path: inset(60% 0 20% 0); transform: translate(2px, -2px); }
    40% { clip-path: inset(10% 0 60% 0); transform: translate(-2px, 2px); }
    60% { clip-path: inset(30% 0 40% 0); transform: translate(1px, -1px); }
    80% { clip-path: inset(80% 0 10% 0); transform: translate(-1px, 1px); }
}
.glitch-text {
    position: relative;
}
.glitch-text::before,
.glitch-text::after {
    content: attr(data-text);
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
}
.glitch-text::before {
    color: var(--blue);
    animation: glitch1 3s infinite linear;
    opacity: 0.7;
}
.glitch-text::after {
    color: #ff0055;
    animation: glitch2 3s infinite linear;
    opacity: 0.7;
}

/* GLOW EFFECTS */
.glow-border {
    position: relative;
    border: 1px solid rgba(255,255,255,0.06);
}
.glow-border::before {
    content: '';
    position: absolute;
    top: -1px; left: -1px;
    right: -1px; bottom: -1px;
    background: linear-gradient(45deg, transparent, var(--blue), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: -1;
}
.glow-border:hover::before {
    opacity: 0.3;
}

/* SCAN LINE OVERLAY */
.scan-overlay {
    position: relative;
}
.scan-overlay::after {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 212, 255, 0.03) 2px,
        rgba(0, 212, 255, 0.03) 4px
    );
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
}
.scan-overlay:hover::after {
    opacity: 1;
}

/* GRID BACKGROUND */
.grid-bg {
    position: relative;
    background-image:
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 40px 40px;
}

/* COUNTER ANIMATION */
.counter-value {
    display: inline-block;
}

/* BACK TO TOP */
.back-to-top {
    position: fixed;
    bottom: 24px; right: 24px;
    width: 40px; height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--black);
    border: 1px solid var(--gray-dark);
    color: var(--white);
    font-size: 1.1rem;
    z-index: 100;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
}
.back-to-top.visible {
    opacity: 1;
    visibility: visible;
}
.back-to-top:hover {
    border-color: var(--blue);
    color: var(--blue);
}

/* RESPONSIVE */
@media (max-width: 768px) {
    .navbar-links { display: none; }
    .navbar-hamburger { display: flex; }
    .section { padding: 80px 20px; }
    .hero-title { font-size: clamp(2.5rem, 12vw, 4rem); }
    .capabilities-grid { grid-template-columns: 1fr; }
    .team-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-inner { flex-direction: column; }
    .footer-links { flex-direction: column; gap: 32px; }
    .section-number { display: none; }
    .split-layout {
        grid-template-columns: 1fr;
        gap: 40px;
    }
    .team-grid-visual {
        max-height: 400px;
    }
}
@media (max-width: 480px) {
    .team-grid { grid-template-columns: 1fr; }
    .manifesto-stats { grid-template-columns: 1fr; }
}
